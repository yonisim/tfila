{
  "name": "electron-quick-start",
  "version": "1.0.0",
  "description": "A minimal Electron application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "screenshot": "electron . --screenshot",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:visual": "playwright test --grep visual",
    "test:report": "playwright show-report",
    "build:css": "tailwindcss -i ./styles/src/tailwind-input.css -o ./styles/tailwind-tfilot-single-page.css --minify",
    "postinstall": "node scripts/copy-tfilot-assets.js"
  },
  "repository": "https://github.com/electron/electron-quick-start",
  "keywords": [
    "Electron",
    "quick",
    "start",
    "tutorial",
    "demo"
  ],
  "author": "GitHub",
  "license": "CC0-1.0",
  "devDependencies": {
    "@fontsource-variable/work-sans": "^5.2.5",
    "@playwright/test": "^1.60.0",
    "autoprefixer": "^10.4.20",
    "electron": "^23.1.3",
    "playwright": "^1.60.0",
    "tailwindcss": "^3.4.17"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "chokidar": "^3.5.3",
    "node-windows": "^1.0.0-beta.8"
  }
}
